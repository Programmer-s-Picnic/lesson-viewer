    {
      "id": "PP01-right-triangle-stars",
      "title": "Right Triangle of Stars",
      "svg_html": "<svg viewBox=\"0 0 860 360\" width=\"100%\" height=\"100%\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Right Triangle of Stars\">\n  <defs>\n    <linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n      <stop offset=\"0\" stop-color=\"#fff7ed\"/>\n      <stop offset=\"1\" stop-color=\"#e0f2fe\"/>\n    </linearGradient>\n    <filter id=\"shadow\" x=\"-10%\" y=\"-10%\" width=\"120%\" height=\"120%\">\n      <feDropShadow dx=\"0\" dy=\"6\" stdDeviation=\"8\" flood-color=\"#0f172a\" flood-opacity=\"0.18\"/>\n    </filter>\n  </defs>\n  <rect x=\"16\" y=\"16\" width=\"828\" height=\"328\" rx=\"28\" fill=\"url(#g)\" stroke=\"#fb923c\" stroke-width=\"3\" filter=\"url(#shadow)\"/>\n  <circle cx=\"72\" cy=\"72\" r=\"34\" fill=\"#fb923c\" opacity=\"0.95\"/>\n  <text x=\"72\" y=\"84\" text-anchor=\"middle\" font-size=\"30\" font-family=\"Arial, sans-serif\" font-weight=\"800\" fill=\"#ffffff\">SQ</text>\n  <text x=\"124\" y=\"62\" font-size=\"26\" font-family=\"Arial, sans-serif\" font-weight=\"800\" fill=\"#0f172a\">Right Triangle of Stars</text>\n  <text x=\"124\" y=\"96\" font-size=\"15\" font-family=\"Arial, sans-serif\" fill=\"#334155\">Pattern Printing • Python loops • Beginner hiring practice</text>\n  <rect x=\"46\" y=\"126\" width=\"376\" height=\"170\" rx=\"18\" fill=\"#ffffff\" stroke=\"#fed7aa\"/>\n  <text x=\"70\" y=\"158\" font-size=\"17\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#9a3412\">Task</text>\n  <foreignObject x=\"70\" y=\"170\" width=\"325\" height=\"76\">\n    <div xmlns=\"http://www.w3.org/1999/xhtml\" style=\"font-family:Arial,sans-serif;font-size:15px;line-height:1.35;color:#334155;\">Read n and print a right-angled triangle with row 1 having 1 star, row 2 having 2 stars, and so on.</div>\n  </foreignObject>\n  <text x=\"70\" y=\"270\" font-size=\"15\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#0f172a\">Sample input: <tspan font-family=\"Consolas, monospace\" fill=\"#0369a1\">n = 5</tspan></text>\n  <rect x=\"450\" y=\"126\" width=\"360\" height=\"170\" rx=\"18\" fill=\"#0f172a\" stroke=\"#38bdf8\"/>\n  <text x=\"470\" y=\"158\" font-size=\"16\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#fbbf24\">Expected shape</text>\n  <text font-size=\"19\" font-family=\"Consolas, 'Courier New', monospace\" fill=\"#e0f2fe\"><tspan x=\"470\" y=\"178\">*</tspan><tspan x=\"470\" y=\"202\">**</tspan><tspan x=\"470\" y=\"226\">***</tspan><tspan x=\"470\" y=\"250\">****</tspan><tspan x=\"470\" y=\"274\">*****</tspan></text>\n  <text x=\"46\" y=\"328\" font-size=\"14\" font-family=\"Arial, sans-serif\" fill=\"#475569\">Core idea: outer loop controls rows, inner loop controls stars.</text>\n</svg>"
    },
    {
      "id": "PP02-inverted-triangle-stars",
      "title": "Inverted Triangle of Stars",
      "svg_html": "<svg viewBox=\"0 0 860 360\" width=\"100%\" height=\"100%\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Inverted Triangle of Stars\">\n  <defs>\n    <linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n      <stop offset=\"0\" stop-color=\"#fff7ed\"/>\n      <stop offset=\"1\" stop-color=\"#e0f2fe\"/>\n    </linearGradient>\n    <filter id=\"shadow\" x=\"-10%\" y=\"-10%\" width=\"120%\" height=\"120%\">\n      <feDropShadow dx=\"0\" dy=\"6\" stdDeviation=\"8\" flood-color=\"#0f172a\" flood-opacity=\"0.18\"/>\n    </filter>\n  </defs>\n  <rect x=\"16\" y=\"16\" width=\"828\" height=\"328\" rx=\"28\" fill=\"url(#g)\" stroke=\"#fb923c\" stroke-width=\"3\" filter=\"url(#shadow)\"/>\n  <circle cx=\"72\" cy=\"72\" r=\"34\" fill=\"#fb923c\" opacity=\"0.95\"/>\n  <text x=\"72\" y=\"84\" text-anchor=\"middle\" font-size=\"30\" font-family=\"Arial, sans-serif\" font-weight=\"800\" fill=\"#ffffff\">SQ</text>\n  <text x=\"124\" y=\"62\" font-size=\"26\" font-family=\"Arial, sans-serif\" font-weight=\"800\" fill=\"#0f172a\">Inverted Triangle of Stars</text>\n  <text x=\"124\" y=\"96\" font-size=\"15\" font-family=\"Arial, sans-serif\" fill=\"#334155\">Pattern Printing • Python loops • Beginner hiring practice</text>\n  <rect x=\"46\" y=\"126\" width=\"376\" height=\"170\" rx=\"18\" fill=\"#ffffff\" stroke=\"#fed7aa\"/>\n  <text x=\"70\" y=\"158\" font-size=\"17\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#9a3412\">Task</text>\n  <foreignObject x=\"70\" y=\"170\" width=\"325\" height=\"76\">\n    <div xmlns=\"http://www.w3.org/1999/xhtml\" style=\"font-family:Arial,sans-serif;font-size:15px;line-height:1.35;color:#334155;\">Read n and print an inverted triangle. The first row has n stars and every next row has one less star.</div>\n  </foreignObject>\n  <text x=\"70\" y=\"270\" font-size=\"15\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#0f172a\">Sample input: <tspan font-family=\"Consolas, monospace\" fill=\"#0369a1\">n = 5</tspan></text>\n  <rect x=\"450\" y=\"126\" width=\"360\" height=\"170\" rx=\"18\" fill=\"#0f172a\" stroke=\"#38bdf8\"/>\n  <text x=\"470\" y=\"158\" font-size=\"16\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#fbbf24\">Expected shape</text>\n  <text font-size=\"19\" font-family=\"Consolas, 'Courier New', monospace\" fill=\"#e0f2fe\"><tspan x=\"470\" y=\"178\">*****</tspan><tspan x=\"470\" y=\"202\">****</tspan><tspan x=\"470\" y=\"226\">***</tspan><tspan x=\"470\" y=\"250\">**</tspan><tspan x=\"470\" y=\"274\">*</tspan></text>\n  <text x=\"46\" y=\"328\" font-size=\"14\" font-family=\"Arial, sans-serif\" fill=\"#475569\">Core idea: loop from n down to 1.</text>\n</svg>"
    },
    {
      "id": "PP03-number-staircase",
      "title": "Number Staircase",
      "svg_html": "<svg viewBox=\"0 0 860 360\" width=\"100%\" height=\"100%\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Number Staircase\">\n  <defs>\n    <linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n      <stop offset=\"0\" stop-color=\"#fff7ed\"/>\n      <stop offset=\"1\" stop-color=\"#e0f2fe\"/>\n    </linearGradient>\n    <filter id=\"shadow\" x=\"-10%\" y=\"-10%\" width=\"120%\" height=\"120%\">\n      <feDropShadow dx=\"0\" dy=\"6\" stdDeviation=\"8\" flood-color=\"#0f172a\" flood-opacity=\"0.18\"/>\n    </filter>\n  </defs>\n  <rect x=\"16\" y=\"16\" width=\"828\" height=\"328\" rx=\"28\" fill=\"url(#g)\" stroke=\"#fb923c\" stroke-width=\"3\" filter=\"url(#shadow)\"/>\n  <circle cx=\"72\" cy=\"72\" r=\"34\" fill=\"#fb923c\" opacity=\"0.95\"/>\n  <text x=\"72\" y=\"84\" text-anchor=\"middle\" font-size=\"30\" font-family=\"Arial, sans-serif\" font-weight=\"800\" fill=\"#ffffff\">SQ</text>\n  <text x=\"124\" y=\"62\" font-size=\"26\" font-family=\"Arial, sans-serif\" font-weight=\"800\" fill=\"#0f172a\">Number Staircase</text>\n  <text x=\"124\" y=\"96\" font-size=\"15\" font-family=\"Arial, sans-serif\" fill=\"#334155\">Pattern Printing • Python loops • Beginner hiring practice</text>\n  <rect x=\"46\" y=\"126\" width=\"376\" height=\"170\" rx=\"18\" fill=\"#ffffff\" stroke=\"#fed7aa\"/>\n  <text x=\"70\" y=\"158\" font-size=\"17\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#9a3412\">Task</text>\n  <foreignObject x=\"70\" y=\"170\" width=\"325\" height=\"76\">\n    <div xmlns=\"http://www.w3.org/1999/xhtml\" style=\"font-family:Arial,sans-serif;font-size:15px;line-height:1.35;color:#334155;\">Read n and print numbers from 1 to the row number on every row.</div>\n  </foreignObject>\n  <text x=\"70\" y=\"270\" font-size=\"15\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#0f172a\">Sample input: <tspan font-family=\"Consolas, monospace\" fill=\"#0369a1\">n = 5</tspan></text>\n  <rect x=\"450\" y=\"126\" width=\"360\" height=\"170\" rx=\"18\" fill=\"#0f172a\" stroke=\"#38bdf8\"/>\n  <text x=\"470\" y=\"158\" font-size=\"16\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#fbbf24\">Expected shape</text>\n  <text font-size=\"19\" font-family=\"Consolas, 'Courier New', monospace\" fill=\"#e0f2fe\"><tspan x=\"470\" y=\"178\">1</tspan><tspan x=\"470\" y=\"202\">12</tspan><tspan x=\"470\" y=\"226\">123</tspan><tspan x=\"470\" y=\"250\">1234</tspan><tspan x=\"470\" y=\"274\">12345</tspan></text>\n  <text x=\"46\" y=\"328\" font-size=\"14\" font-family=\"Arial, sans-serif\" fill=\"#475569\">Core idea: nested loops and print without newline inside a row.</text>\n</svg>"
    },
    {
      "id": "PP04-same-number-rows",
      "title": "Same Number Rows",
      "svg_html": "<svg viewBox=\"0 0 860 360\" width=\"100%\" height=\"100%\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Same Number Rows\">\n  <defs>\n    <linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n      <stop offset=\"0\" stop-color=\"#fff7ed\"/>\n      <stop offset=\"1\" stop-color=\"#e0f2fe\"/>\n    </linearGradient>\n    <filter id=\"shadow\" x=\"-10%\" y=\"-10%\" width=\"120%\" height=\"120%\">\n      <feDropShadow dx=\"0\" dy=\"6\" stdDeviation=\"8\" flood-color=\"#0f172a\" flood-opacity=\"0.18\"/>\n    </filter>\n  </defs>\n  <rect x=\"16\" y=\"16\" width=\"828\" height=\"328\" rx=\"28\" fill=\"url(#g)\" stroke=\"#fb923c\" stroke-width=\"3\" filter=\"url(#shadow)\"/>\n  <circle cx=\"72\" cy=\"72\" r=\"34\" fill=\"#fb923c\" opacity=\"0.95\"/>\n  <text x=\"72\" y=\"84\" text-anchor=\"middle\" font-size=\"30\" font-family=\"Arial, sans-serif\" font-weight=\"800\" fill=\"#ffffff\">SQ</text>\n  <text x=\"124\" y=\"62\" font-size=\"26\" font-family=\"Arial, sans-serif\" font-weight=\"800\" fill=\"#0f172a\">Same Number Rows</text>\n  <text x=\"124\" y=\"96\" font-size=\"15\" font-family=\"Arial, sans-serif\" fill=\"#334155\">Pattern Printing • Python loops • Beginner hiring practice</text>\n  <rect x=\"46\" y=\"126\" width=\"376\" height=\"170\" rx=\"18\" fill=\"#ffffff\" stroke=\"#fed7aa\"/>\n  <text x=\"70\" y=\"158\" font-size=\"17\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#9a3412\">Task</text>\n  <foreignObject x=\"70\" y=\"170\" width=\"325\" height=\"76\">\n    <div xmlns=\"http://www.w3.org/1999/xhtml\" style=\"font-family:Arial,sans-serif;font-size:15px;line-height:1.35;color:#334155;\">Read n and print row number repeated row times. Row 4 should print 4444.</div>\n  </foreignObject>\n  <text x=\"70\" y=\"270\" font-size=\"15\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#0f172a\">Sample input: <tspan font-family=\"Consolas, monospace\" fill=\"#0369a1\">n = 5</tspan></text>\n  <rect x=\"450\" y=\"126\" width=\"360\" height=\"170\" rx=\"18\" fill=\"#0f172a\" stroke=\"#38bdf8\"/>\n  <text x=\"470\" y=\"158\" font-size=\"16\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#fbbf24\">Expected shape</text>\n  <text font-size=\"19\" font-family=\"Consolas, 'Courier New', monospace\" fill=\"#e0f2fe\"><tspan x=\"470\" y=\"178\">1</tspan><tspan x=\"470\" y=\"202\">22</tspan><tspan x=\"470\" y=\"226\">333</tspan><tspan x=\"470\" y=\"250\">4444</tspan><tspan x=\"470\" y=\"274\">55555</tspan></text>\n  <text x=\"46\" y=\"328\" font-size=\"14\" font-family=\"Arial, sans-serif\" fill=\"#475569\">Core idea: row value and row length are both controlled by i.</text>\n</svg>"
    },
    {
      "id": "PP05-centered-pyramid",
      "title": "Centered Star Pyramid",
      "svg_html": "<svg viewBox=\"0 0 860 360\" width=\"100%\" height=\"100%\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Centered Star Pyramid\">\n  <defs>\n    <linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n      <stop offset=\"0\" stop-color=\"#fff7ed\"/>\n      <stop offset=\"1\" stop-color=\"#e0f2fe\"/>\n    </linearGradient>\n    <filter id=\"shadow\" x=\"-10%\" y=\"-10%\" width=\"120%\" height=\"120%\">\n      <feDropShadow dx=\"0\" dy=\"6\" stdDeviation=\"8\" flood-color=\"#0f172a\" flood-opacity=\"0.18\"/>\n    </filter>\n  </defs>\n  <rect x=\"16\" y=\"16\" width=\"828\" height=\"328\" rx=\"28\" fill=\"url(#g)\" stroke=\"#fb923c\" stroke-width=\"3\" filter=\"url(#shadow)\"/>\n  <circle cx=\"72\" cy=\"72\" r=\"34\" fill=\"#fb923c\" opacity=\"0.95\"/>\n  <text x=\"72\" y=\"84\" text-anchor=\"middle\" font-size=\"30\" font-family=\"Arial, sans-serif\" font-weight=\"800\" fill=\"#ffffff\">SQ</text>\n  <text x=\"124\" y=\"62\" font-size=\"26\" font-family=\"Arial, sans-serif\" font-weight=\"800\" fill=\"#0f172a\">Centered Star Pyramid</text>\n  <text x=\"124\" y=\"96\" font-size=\"15\" font-family=\"Arial, sans-serif\" fill=\"#334155\">Pattern Printing • Python loops • Beginner hiring practice</text>\n  <rect x=\"46\" y=\"126\" width=\"376\" height=\"170\" rx=\"18\" fill=\"#ffffff\" stroke=\"#fed7aa\"/>\n  <text x=\"70\" y=\"158\" font-size=\"17\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#9a3412\">Task</text>\n  <foreignObject x=\"70\" y=\"170\" width=\"325\" height=\"76\">\n    <div xmlns=\"http://www.w3.org/1999/xhtml\" style=\"font-family:Arial,sans-serif;font-size:15px;line-height:1.35;color:#334155;\">Read n and print a centered pyramid. Use spaces first, then odd number of stars.</div>\n  </foreignObject>\n  <text x=\"70\" y=\"270\" font-size=\"15\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#0f172a\">Sample input: <tspan font-family=\"Consolas, monospace\" fill=\"#0369a1\">n = 5</tspan></text>\n  <rect x=\"450\" y=\"126\" width=\"360\" height=\"170\" rx=\"18\" fill=\"#0f172a\" stroke=\"#38bdf8\"/>\n  <text x=\"470\" y=\"158\" font-size=\"16\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#fbbf24\">Expected shape</text>\n  <text font-size=\"19\" font-family=\"Consolas, 'Courier New', monospace\" fill=\"#e0f2fe\"><tspan x=\"470\" y=\"178\">    *</tspan><tspan x=\"470\" y=\"202\">   ***</tspan><tspan x=\"470\" y=\"226\">  *****</tspan><tspan x=\"470\" y=\"250\"> *******</tspan><tspan x=\"470\" y=\"274\">*********</tspan></text>\n  <text x=\"46\" y=\"328\" font-size=\"14\" font-family=\"Arial, sans-serif\" fill=\"#475569\">Core idea: spaces = n - row, stars = 2 * row - 1.</text>\n</svg>"
    },
    {
      "id": "PP06-inverted-pyramid",
      "title": "Inverted Star Pyramid",
      "svg_html": "<svg viewBox=\"0 0 860 360\" width=\"100%\" height=\"100%\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Inverted Star Pyramid\">\n  <defs>\n    <linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n      <stop offset=\"0\" stop-color=\"#fff7ed\"/>\n      <stop offset=\"1\" stop-color=\"#e0f2fe\"/>\n    </linearGradient>\n    <filter id=\"shadow\" x=\"-10%\" y=\"-10%\" width=\"120%\" height=\"120%\">\n      <feDropShadow dx=\"0\" dy=\"6\" stdDeviation=\"8\" flood-color=\"#0f172a\" flood-opacity=\"0.18\"/>\n    </filter>\n  </defs>\n  <rect x=\"16\" y=\"16\" width=\"828\" height=\"328\" rx=\"28\" fill=\"url(#g)\" stroke=\"#fb923c\" stroke-width=\"3\" filter=\"url(#shadow)\"/>\n  <circle cx=\"72\" cy=\"72\" r=\"34\" fill=\"#fb923c\" opacity=\"0.95\"/>\n  <text x=\"72\" y=\"84\" text-anchor=\"middle\" font-size=\"30\" font-family=\"Arial, sans-serif\" font-weight=\"800\" fill=\"#ffffff\">SQ</text>\n  <text x=\"124\" y=\"62\" font-size=\"26\" font-family=\"Arial, sans-serif\" font-weight=\"800\" fill=\"#0f172a\">Inverted Star Pyramid</text>\n  <text x=\"124\" y=\"96\" font-size=\"15\" font-family=\"Arial, sans-serif\" fill=\"#334155\">Pattern Printing • Python loops • Beginner hiring practice</text>\n  <rect x=\"46\" y=\"126\" width=\"376\" height=\"170\" rx=\"18\" fill=\"#ffffff\" stroke=\"#fed7aa\"/>\n  <text x=\"70\" y=\"158\" font-size=\"17\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#9a3412\">Task</text>\n  <foreignObject x=\"70\" y=\"170\" width=\"325\" height=\"76\">\n    <div xmlns=\"http://www.w3.org/1999/xhtml\" style=\"font-family:Arial,sans-serif;font-size:15px;line-height:1.35;color:#334155;\">Read n and print an upside-down centered pyramid with stars decreasing by two each row.</div>\n  </foreignObject>\n  <text x=\"70\" y=\"270\" font-size=\"15\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#0f172a\">Sample input: <tspan font-family=\"Consolas, monospace\" fill=\"#0369a1\">n = 5</tspan></text>\n  <rect x=\"450\" y=\"126\" width=\"360\" height=\"170\" rx=\"18\" fill=\"#0f172a\" stroke=\"#38bdf8\"/>\n  <text x=\"470\" y=\"158\" font-size=\"16\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#fbbf24\">Expected shape</text>\n  <text font-size=\"19\" font-family=\"Consolas, 'Courier New', monospace\" fill=\"#e0f2fe\"><tspan x=\"470\" y=\"178\">*********</tspan><tspan x=\"470\" y=\"202\"> *******</tspan><tspan x=\"470\" y=\"226\">  *****</tspan><tspan x=\"470\" y=\"250\">   ***</tspan><tspan x=\"470\" y=\"274\">    *</tspan></text>\n  <text x=\"46\" y=\"328\" font-size=\"14\" font-family=\"Arial, sans-serif\" fill=\"#475569\">Core idea: spaces increase, stars decrease.</text>\n</svg>"
    },
    {
      "id": "PP07-hollow-square",
      "title": "Hollow Square",
      "svg_html": "<svg viewBox=\"0 0 860 360\" width=\"100%\" height=\"100%\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Hollow Square\">\n  <defs>\n    <linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n      <stop offset=\"0\" stop-color=\"#fff7ed\"/>\n      <stop offset=\"1\" stop-color=\"#e0f2fe\"/>\n    </linearGradient>\n    <filter id=\"shadow\" x=\"-10%\" y=\"-10%\" width=\"120%\" height=\"120%\">\n      <feDropShadow dx=\"0\" dy=\"6\" stdDeviation=\"8\" flood-color=\"#0f172a\" flood-opacity=\"0.18\"/>\n    </filter>\n  </defs>\n  <rect x=\"16\" y=\"16\" width=\"828\" height=\"328\" rx=\"28\" fill=\"url(#g)\" stroke=\"#fb923c\" stroke-width=\"3\" filter=\"url(#shadow)\"/>\n  <circle cx=\"72\" cy=\"72\" r=\"34\" fill=\"#fb923c\" opacity=\"0.95\"/>\n  <text x=\"72\" y=\"84\" text-anchor=\"middle\" font-size=\"30\" font-family=\"Arial, sans-serif\" font-weight=\"800\" fill=\"#ffffff\">SQ</text>\n  <text x=\"124\" y=\"62\" font-size=\"26\" font-family=\"Arial, sans-serif\" font-weight=\"800\" fill=\"#0f172a\">Hollow Square</text>\n  <text x=\"124\" y=\"96\" font-size=\"15\" font-family=\"Arial, sans-serif\" fill=\"#334155\">Pattern Printing • Python loops • Beginner hiring practice</text>\n  <rect x=\"46\" y=\"126\" width=\"376\" height=\"170\" rx=\"18\" fill=\"#ffffff\" stroke=\"#fed7aa\"/>\n  <text x=\"70\" y=\"158\" font-size=\"17\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#9a3412\">Task</text>\n  <foreignObject x=\"70\" y=\"170\" width=\"325\" height=\"76\">\n    <div xmlns=\"http://www.w3.org/1999/xhtml\" style=\"font-family:Arial,sans-serif;font-size:15px;line-height:1.35;color:#334155;\">Read n and print a square border. Only the first row, last row, first column, and last column contain stars.</div>\n  </foreignObject>\n  <text x=\"70\" y=\"270\" font-size=\"15\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#0f172a\">Sample input: <tspan font-family=\"Consolas, monospace\" fill=\"#0369a1\">n = 5</tspan></text>\n  <rect x=\"450\" y=\"126\" width=\"360\" height=\"170\" rx=\"18\" fill=\"#0f172a\" stroke=\"#38bdf8\"/>\n  <text x=\"470\" y=\"158\" font-size=\"16\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#fbbf24\">Expected shape</text>\n  <text font-size=\"19\" font-family=\"Consolas, 'Courier New', monospace\" fill=\"#e0f2fe\"><tspan x=\"470\" y=\"178\">*****</tspan><tspan x=\"470\" y=\"202\">*   *</tspan><tspan x=\"470\" y=\"226\">*   *</tspan><tspan x=\"470\" y=\"250\">*   *</tspan><tspan x=\"470\" y=\"274\">*****</tspan></text>\n  <text x=\"46\" y=\"328\" font-size=\"14\" font-family=\"Arial, sans-serif\" fill=\"#475569\">Core idea: check boundary positions: row 1/n or column 1/n.</text>\n</svg>"
    },
    {
      "id": "PP08-butterfly-pattern",
      "title": "Butterfly Pattern",
      "svg_html": "<svg viewBox=\"0 0 860 360\" width=\"100%\" height=\"100%\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Butterfly Pattern\">\n  <defs>\n    <linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n      <stop offset=\"0\" stop-color=\"#fff7ed\"/>\n      <stop offset=\"1\" stop-color=\"#e0f2fe\"/>\n    </linearGradient>\n    <filter id=\"shadow\" x=\"-10%\" y=\"-10%\" width=\"120%\" height=\"120%\">\n      <feDropShadow dx=\"0\" dy=\"6\" stdDeviation=\"8\" flood-color=\"#0f172a\" flood-opacity=\"0.18\"/>\n    </filter>\n  </defs>\n  <rect x=\"16\" y=\"16\" width=\"828\" height=\"328\" rx=\"28\" fill=\"url(#g)\" stroke=\"#fb923c\" stroke-width=\"3\" filter=\"url(#shadow)\"/>\n  <circle cx=\"72\" cy=\"72\" r=\"34\" fill=\"#fb923c\" opacity=\"0.95\"/>\n  <text x=\"72\" y=\"84\" text-anchor=\"middle\" font-size=\"30\" font-family=\"Arial, sans-serif\" font-weight=\"800\" fill=\"#ffffff\">SQ</text>\n  <text x=\"124\" y=\"62\" font-size=\"26\" font-family=\"Arial, sans-serif\" font-weight=\"800\" fill=\"#0f172a\">Butterfly Pattern</text>\n  <text x=\"124\" y=\"96\" font-size=\"15\" font-family=\"Arial, sans-serif\" fill=\"#334155\">Pattern Printing • Python loops • Beginner hiring practice</text>\n  <rect x=\"46\" y=\"126\" width=\"376\" height=\"170\" rx=\"18\" fill=\"#ffffff\" stroke=\"#fed7aa\"/>\n  <text x=\"70\" y=\"158\" font-size=\"17\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#9a3412\">Task</text>\n  <foreignObject x=\"70\" y=\"170\" width=\"325\" height=\"76\">\n    <div xmlns=\"http://www.w3.org/1999/xhtml\" style=\"font-family:Arial,sans-serif;font-size:15px;line-height:1.35;color:#334155;\">Read n and print a butterfly pattern using two mirrored star wings separated by spaces.</div>\n  </foreignObject>\n  <text x=\"70\" y=\"270\" font-size=\"15\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#0f172a\">Sample input: <tspan font-family=\"Consolas, monospace\" fill=\"#0369a1\">n = 4</tspan></text>\n  <rect x=\"450\" y=\"126\" width=\"360\" height=\"170\" rx=\"18\" fill=\"#0f172a\" stroke=\"#38bdf8\"/>\n  <text x=\"470\" y=\"158\" font-size=\"16\" font-family=\"Arial, sans-serif\" font-weight=\"700\" fill=\"#fbbf24\">Expected shape</text>\n  <text font-size=\"19\" font-family=\"Consolas, 'Courier New', monospace\" fill=\"#e0f2fe\"><tspan x=\"470\" y=\"178\">*      *</tspan><tspan x=\"470\" y=\"202\">**    **</tspan><tspan x=\"470\" y=\"226\">***  ***</tspan><tspan x=\"470\" y=\"250\">********</tspan><tspan x=\"470\" y=\"274\">********</tspan><tspan x=\"470\" y=\"298\">***  ***</tspan><tspan x=\"470\" y=\"322\">**    **</tspan><tspan x=\"470\" y=\"346\">*      *</tspan></text>\n  <text x=\"46\" y=\"328\" font-size=\"14\" font-family=\"Arial, sans-serif\" fill=\"#475569\">Core idea: combine left stars, middle spaces, and right stars.</text>\n</svg>"
    }
  ]
